<?xml version="1.0"?>
<configuration>
	<connectionStrings>
		<add name="AQOONHUB_DB"
			 connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=AQOONHUB_DB;Integrated Security=True;MultipleActiveResultSets=True"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>

	<system.web>
		<compilation debug="true" targetFramework="4.8"/>
		<httpRuntime targetFramework="4.8"/>

		<authentication mode="Forms">
			<forms loginUrl="~/Pages/Login.aspx" timeout="30" slidingExpiration="true"/>
		</authentication>

		<authorization>
			<deny users="?"/>
		</authorization>

		<sessionState mode="InProc" timeout="30"/>

		<pages masterPageFile="~/MasterPages/MainMaster.master">
			<namespaces>
				<add namespace="AQOONHUB.Models"/>
				<add namespace="AQOONHUB.DataAccess"/>
				<add namespace="AQOONHUB.BusinessLogic"/>
				<add namespace="AQOONHUB.Utilities"/>
			</namespaces>
		</pages>
	</system.web>

	<location path="Pages/Login.aspx">
		<system.web>
			<authorization>
				<allow users="*"/>
			</authorization>
		</system.web>
	</location>
</configuration>